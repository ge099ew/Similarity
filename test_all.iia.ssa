# Similarity - Application
# type: AllFeatures
# value: Test

function w $test_pointer() {
@start
    %x.ptr =l alloc4 4
    storew 42, %x.ptr
    %t1 =w loadw %x.ptr
    ret %t1
}

function w $test_cast() {
@start
    %x.ptr =l alloc4 4
    storew 10, %x.ptr
    %y.ptr =l alloc4 4
    %t2 =w loadw %x.ptr
    %cast3 =s swtof %t2
    stores %cast3, %y.ptr
    ret 0
}

function w $test_risk() {
@start
    %x.ptr =l alloc4 4
    storew 99, %x.ptr
    # Mem[risk]: unsafe block begin
    %val.ptr =l alloc4 4
    %daddr4 =l loadl %x.ptr
    %deref5 =w loadw %daddr4
    storew %deref5, %val.ptr
    # Mem[risk]: unsafe block end
    ret 0
}

function w $test_overflow_check() {
@start
    %x.ptr =l alloc4 4
    storew 2147483647, %x.ptr
    %t6 =w loadw %x.ptr
    ret %t6
}

export function w $sim_main() {
@start
    %a.ptr =l alloc4 4
    %ret7 =w call $test_pointer()
    storew %ret7, %a.ptr
    %b.ptr =l alloc4 4
    %ret8 =w call $test_cast()
    storew %ret8, %b.ptr
    %c.ptr =l alloc4 4
    %ret9 =w call $test_risk()
    storew %ret9, %c.ptr
    %d.ptr =l alloc4 4
    %ret10 =w call $test_overflow_check()
    storew %ret10, %d.ptr
    %t11 =w loadw %a.ptr
    ret %t11
}

