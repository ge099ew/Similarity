  Variable[let{int(val0:59)}],
  Variable[let{int(val1:82)}],
  Variable[let{int(val2:47)}],
  Variable[let{int(val3:21)}],
  Variable[let{int(val4:48)}],
  Loop[for{int(i:0), less(i:10), step{1}},
    Body[
      Variable[let{int(tmp0:+{int(val0:i)})}],
      Variable[let{int(tmp1:+{int(val1:i)})}],
      Variable[let{int(tmp2:+{int(val2:i)})}],
      Variable[let{int(tmp3:+{int(val3:i)})}],
      Variable[let{int(tmp4:+{int(val4:i)})}],
      If[check{lesseq(tmp0:50)},
        True[
          Variable[let{int(val0:+{int(val0:1)})}],
          Variable[let{int(val1:+{int(val1:2)})}]
        ],
        False[
          Variable[let{int(val0:-{int(val0:1)})}],
          Variable[let{int(val1:-{int(val1:2)})}]
        ]
      ],
      Loop[for{int(j:0), less(j:5), step{1}},
        Body[
          Variable[let{int(tmp2:+{int(tmp2:j)})}],
          If[check{lesseq(tmp2:20)},
            True[Variable[let{int(val2:+{int(val2:1)})}]],
            False[Variable[let{int(val2:-{int(val2:1)})}]]
          ]
        ]
      ]
    ]
  ],
  return{val0}
}]

