# Similarity - Application
# type: RPG
# name: TestGame
# value: Game

# import mylib
%hp =w copy 100
%MAX_HP =w copy 100
function w $heal(w %amount) {
@start
    %cond4 =w clew %hp, 0
    jnz %cond4, @true1, @false2
@true1
        # Fatal: GameOver - HPが0以下
        call $exit(w 1)
        jmp @end3
@false2
        %expr5 =w add %hp, %amount
        %hp =w copy %expr5
        jmp @end3
@end3
    ret 0
}

export function w $main() {
@start
    %ret6 =w call $heal(w 10)
    ret 0
}


